# Environment Variables for Cold Reach Automation
# Copy this file to .env and fill in your values

# Gmail SMTP Configuration
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Sender Info
SENDER_NAME=Your Full Name
SENDER_INTRO=Final year CS student at XYZ University with experience in ML and full-stack development

# Server
PORT=3000
BASE_URL=http://localhost:3000

# Apollo.io (for email enrichment)
APOLLO_API_KEY=

# Hunter.io (Optional - for email verification)
HUNTER_API_KEY=

# Outreach Settings
DAILY_EMAIL_LIMIT=20
MIN_SEND_INTERVAL_MS=120000
FOLLOW_UP_DAY_1=3
FOLLOW_UP_DAY_2=7
